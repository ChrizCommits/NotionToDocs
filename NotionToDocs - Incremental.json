      "parameters": {
        "jsCode": "const doc = $input.first().json.content ?? '';\nconst documentId = $input.first().json.documentId;\n\nconst regex = /RECIPE_START:\\s*([a-z0-9-]+)/gi;\n\nconst ids = [];\nlet match;\n\nwhile ((match = regex.exec(doc)) !== null) {\n  ids.push(match[1]);\n}\n\nreturn ids.map(pageId => ({\n  json: {\n    pageId,\n    documentId,\n  },\n}));"
      },
