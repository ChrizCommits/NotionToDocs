    {
      "parameters": {
        "jsCode": "const docIds = $input.all()\n  .map(i => i.json.pageId)\n  .filter(id => id && id !== '--'); // crapfilter\n\nconst notionIds = $('Fetch recipes').all().map(i => i.json.id);\n\nconst notionSet = new Set(notionIds);\n\nconst deleted = docIds.filter(id => !notionSet.has(id));\n\nreturn deleted.map(id => ({\n  json: {\n    pageId: id,\n    documentId: $input.first().json.documentId,\n  },\n}));"
      },
