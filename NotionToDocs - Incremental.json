    {
      "parameters": {
        "jsCode": "const doc = $('Get document for cleanup').first().json.content ?? '';\nconst documentId = $('Get document for cleanup').first().json.documentId;\n\nconst output = [];\n\nfor (const item of $input.all()) {\n  const pageId = item.json.pageId;\n\n  const startMarker = `<!-- RECIPE_START: ${pageId}`;\n  const endMarker = `RECIPE_END: ${pageId} -->`;\n\n  const startIndex = doc.indexOf(startMarker);\n  if (startIndex === -1) continue;\n\n  const endIndex = doc.indexOf(endMarker, startIndex);\n  if (endIndex === -1) continue;\n\n  const oldContent = doc.slice(startIndex, endIndex + endMarker.length);\n\n  output.push({\n    json: {\n      pageId,\n      documentId,\n      oldContent,\n      newContent: '',\n    },\n  });\n}\n\nreturn output;"
      },
