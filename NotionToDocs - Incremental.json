    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst grouped = new Map();\n\nfor (const item of items) {\n  const block = item.json;\n\n  const pageId =\n    block.parent?.page_id ??\n    block.root_id;\n\n  if (!pageId) continue;\n\n  if (!grouped.has(pageId)) {\n    grouped.set(pageId, {\n      pageId,\n      blocks: [],\n    });\n  }\n\n  grouped.get(pageId).blocks.push(block);\n}\n\nreturn Array.from(grouped.values()).map(group => ({\n  json: group,\n}));"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        720,
        128
      ],
      "id": "0e7779ee-191c-431e-886e-34c2fbcf59b6",
      "name": "Group blocks by recipe"
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst pageId = $input.first().json.pageId;\n\nconst cleanId = id => String(id || '').replace(/-/g, '');\n\nconst recipe = $('Fetch recipes').all()\n  .map(i => i.json)\n  .find(p => cleanId(p.id) === cleanId(pageId));\n\nif (!recipe) {\n  throw new Error(`Recipe meta not found for pageId ${pageId}`);\n}\n\nconst title =\n  recipe.properties?.Name?.title?.[0]?.plain_text ||\n  recipe.property_name ||\n  recipe.name ||\n  'Ohne Titel';\n\nconst rating =\n  recipe.property_rating_calc ||\n  recipe.property_rating ||\n  '';\n\nconst tags = [\n  ...(recipe.property_tags || []),\n  recipe.property_meal_type || '',\n].filter(Boolean);\n\nconst description =\n  recipe.property_description ||\n  '';\n\nfunction blockToText(block) {\n  const type = block.type;\n  const text = String(block.content || '').trim();\n\n  if (!text) return '';\n\n  if (type === 'heading_1') return `# ${text}`;\n  if (type === 'heading_2') return `## ${text}`;\n  if (type === 'heading_3') return `### ${text}`;\n  if (type === 'bulleted_list_item') return `- ${text}`;\n  if (type === 'numbered_list_item') return `1. ${text}`;\n  if (type === 'to_do') return `[ ] ${text}`;\n\n  if (['paragraph', 'quote', 'callout', 'toggle'].includes(type)) {\n    return text;\n  }\n\n  return '';\n}\n\nconst blocks = items.flatMap(item => item.json.blocks ?? [item.json]);\n\nconst content = blocks\n  .map(blockToText)\n  .filter(Boolean)\n  .join('\\n');\n\nconst body = [\n  `Title: ${title}`,\n  rating ? `Rating: ${rating}` : '',\n  tags.length ? `Tags: ${[...new Set(tags)].join(', ')}` : '',\n  description ? `Description: ${description}` : '',\n  '',\n  `Content:`,\n  content,\n]\n  .filter(line => line !== '')\n  .join('\\n');\n\nconst newContent = `RECIPE_START: ${pageId}\n${body}\nRECIPE_END: ${pageId}`;\n\nreturn [\n  {\n    json: {\n      pageId,\n      newContent,\n      blockCount: blocks.length,\n    },\n  },\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        944,
        128
      ],
      "id": "c0ddbc2c-671c-4f63-b976-742cb202ff62",
      "name": "Build new recipe content"
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const oldDoc = $json.content;\nconst pageId = $json.pageId;\n\nconst startMarker = `RECIPE_START: ${pageId}`;\nconst endMarker = `RECIPE_END: ${pageId}`;\n\nconst startIndex = oldDoc.indexOf(startMarker);\n\nif (startIndex === -1) {\n  throw new Error(`Start marker not found for pageId ${pageId}`);\n}\n\nconst endIndex = oldDoc.indexOf(endMarker, startIndex);\n\nif (endIndex === -1) {\n  throw new Error(`End marker not found for pageId ${pageId}`);\n}\n\nconst endMarkerEnd = endIndex + endMarker.length;\n\n// 🔥 kompletter Block (unverändert!)\nconst oldContent = oldDoc.slice(startIndex, endMarkerEnd);\n\nreturn {\n  pageId,\n  oldContent,\n  startIndex,\n  endIndex: endMarkerEnd,\n  documentId: $json.documentId,\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        944,
        384
      ],
      "id": "32a6d3fb-cd4a-40bc-b961-9bfe17666a3b",
      "name": "Build old recipe content",
      "retryOnFail": true,
      "alwaysOutputData": false
    },
    {
      "parameters": {
        "jsCode": "function normalizeNew(value) {\n  return String(value ?? '')\n    .replace(/\\r\\n/g, '\\n')\n    .replace(/\\u00A0/g, ' ')\n    .trim();\n}\n\nconst item = $input.first().json;\n\nreturn {\n  pageId: item.pageId,\n  oldContent: item.oldContent,\n  newContent: normalizeNew(item.newContent),\n  documentId: item.documentId,\n};"
      },
